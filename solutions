<script>
function toggleMenu(){document.getElementById('mobileNav').classList.toggle('open');document.getElementById('ham').classList.toggle('open')}
function closeMenu(){document.getElementById('mobileNav').classList.remove('open');document.getElementById('ham').classList.remove('open')}

// Scroll reveal
const revEls = document.querySelectorAll('.reveal');
const revObs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');revObs.unobserve(e.target)}});
},{threshold:0.1});
revEls.forEach(el=>revObs.observe(el));

// Sticky scroll logic
const blocks = document.querySelectorAll('.sol-block');
const navItems = document.querySelectorAll('.snav-item');
const progress = document.getElementById('snavProgress');
const solBlocksEl = document.getElementById('solBlocks');

function goTo(i){blocks[i].scrollIntoView({behavior:'smooth',block:'center'})}

function onScroll(){
  const wH = window.innerHeight;
  let active = 0;

  blocks.forEach((b,i)=>{
    const r = b.getBoundingClientRect();
    const mid = r.top + r.height/2;
    if(mid < wH * 0.58) active = i;
    const inView = r.top < wH*0.65 && r.bottom > wH*0.35;
    b.classList.toggle('in-view', inView);
  });

  navItems.forEach((n,i)=>n.classList.toggle('active', i===active));

  // progress bar height
  if(solBlocksEl){
    const r = solBlocksEl.getBoundingClientRect();
    const total = solBlocksEl.offsetHeight - wH;
    const pct = Math.max(0,Math.min(100,(-r.top/total)*100));
    if(progress) progress.style.height = pct+'%';
  }
}

window.addEventListener('scroll', onScroll, {passive:true});
onScroll();
</script>
