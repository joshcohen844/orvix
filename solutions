<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Orvix — Solutions</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Fraunces:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#F8F7F4;--ink:#0D1117;--ink2:#1C2333;
  --mid:#4A5568;--muted:#8896A5;
  --teal:#0EA27A;--teal-light:#12C994;--teal-pale:#E8F8F3;
  --border:#E2E8F0;--border-dark:#CBD5E0;
  --dark:#0D1117;--dark2:#141B2D;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--ink);font-family:'Plus Jakarta Sans',sans-serif;overflow-x:hidden;line-height:1.6}

.reveal{opacity:0;transform:translateY(28px);transition:opacity 0.65s ease,transform 0.65s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
.delay-1{transition-delay:.1s}.delay-2{transition-delay:.2s}.delay-3{transition-delay:.3s}.delay-4{transition-delay:.4s}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 60px;height:72px;display:flex;align-items:center;justify-content:space-between;background:rgba(248,247,244,0.96);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);box-shadow:0 2px 24px rgba(0,0,0,0.06)}
.logo{font-size:22px;font-weight:700;color:var(--ink);letter-spacing:-0.5px;text-decoration:none}
.logo span{color:var(--teal)}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{color:var(--mid);text-decoration:none;font-size:14px;font-weight:500;transition:color 0.2s}
.nav-links a:hover{color:var(--ink)}
.nav-links a.active{color:var(--ink);font-weight:700;border-bottom:2px solid var(--teal);padding-bottom:2px}
.nav-cta{background:var(--teal);color:white;padding:10px 24px;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;border:none;font-family:'Plus Jakarta Sans',sans-serif;transition:all 0.2s;text-decoration:none}
.nav-cta:hover{background:var(--teal-light)}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
.hamburger span{width:22px;height:2px;background:var(--ink);border-radius:2px;display:block;transition:all 0.3s}
.hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.hamburger.open span:nth-child(2){opacity:0}
.hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
.mobile-nav{display:none;position:fixed;top:72px;left:0;right:0;z-index:99;background:white;border-bottom:1px solid var(--border);padding:16px 24px;flex-direction:column}
.mobile-nav.open{display:flex}
.mobile-nav a{color:var(--mid);text-decoration:none;font-size:16px;font-weight:500;padding:14px 0;border-bottom:1px solid var(--border);display:block}
.mobile-nav .mob-cta{margin-top:12px;background:var(--teal);color:white;text-align:center;border-radius:10px;padding:14px;font-weight:600;border-bottom:none}

/* PAGE HERO */
.page-hero{padding:140px 60px 80px;background:linear-gradient(180deg,white,var(--bg));border-bottom:1px solid var(--border);position:relative;overflow:hidden}
.page-hero::before{content:'';position:absolute;top:-100px;right:-150px;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(14,162,122,0.05),transparent 65%);pointer-events:none}
.page-hero-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.ph-tag{display:inline-flex;align-items:center;gap:6px;background:var(--teal-pale);border-radius:4px;padding:4px 12px;font-size:11px;font-weight:600;color:var(--teal);letter-spacing:0.5px;text-transform:uppercase;margin-bottom:20px}
.ph-tag-dot{width:6px;height:6px;border-radius:50%;background:var(--teal);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}
.page-hero h1{font-family:'Fraunces',serif;font-size:clamp(34px,4vw,58px);font-weight:300;line-height:1.1;letter-spacing:-1.5px;margin-bottom:20px}
.page-hero h1 em{font-style:italic;color:var(--teal)}
.page-hero-sub{font-size:17px;color:var(--mid);line-height:1.8;margin-bottom:36px;max-width:460px}
.page-hero-actions{display:flex;gap:12px;flex-wrap:wrap}
.btn-primary{background:var(--teal);color:white;padding:13px 28px;border-radius:10px;font-weight:600;font-size:15px;cursor:pointer;border:none;font-family:'Plus Jakarta Sans',sans-serif;transition:all 0.2s;text-decoration:none;display:inline-block}
.btn-primary:hover{background:var(--teal-light);transform:translateY(-2px);box-shadow:0 8px 24px rgba(14,162,122,0.25)}
.btn-ghost{background:transparent;color:var(--ink);padding:13px 28px;border-radius:10px;font-weight:500;font-size:15px;cursor:pointer;border:1.5px solid var(--border-dark);font-family:'Plus Jakarta Sans',sans-serif;transition:all 0.2s;text-decoration:none;display:inline-block}
.btn-ghost:hover{border-color:var(--teal);color:var(--teal)}
.hero-mini-cards{display:flex;flex-direction:column;gap:10px}
.hmc{display:flex;align-items:center;gap:14px;background:white;border:1px solid var(--border);border-radius:14px;padding:16px 20px;box-shadow:0 4px 16px rgba(0,0,0,0.05);transition:all 0.25s;cursor:default}
.hmc:hover{transform:translateX(6px);border-color:rgba(14,162,122,0.3);box-shadow:0 6px 24px rgba(14,162,122,0.1)}
.hmc-icon{width:36px;height:36px;border-radius:9px;background:var(--teal-pale);display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.hmc-title{font-size:14px;font-weight:600;color:var(--ink);line-height:1.3}
.hmc-sub{font-size:12px;color:var(--muted);margin-top:1px}

/* STICKY SCROLL */
.sticky-section{padding:80px 60px 120px;max-width:1380px;margin:0 auto}
.sticky-section-head{text-align:center;margin-bottom:80px}
.ssh-tag{display:inline-flex;align-items:center;gap:6px;background:var(--teal-pale);border-radius:4px;padding:4px 12px;font-size:11px;font-weight:600;color:var(--teal);letter-spacing:0.5px;text-transform:uppercase;margin-bottom:16px}
.sticky-section-head h2{font-family:'Fraunces',serif;font-size:clamp(28px,3vw,46px);font-weight:300;letter-spacing:-1px;line-height:1.1}
.sticky-section-head h2 em{font-style:italic;color:var(--teal)}
.sticky-section-head p{font-size:16px;color:var(--mid);max-width:480px;margin:14px auto 0;line-height:1.75}

.sticky-wrap{display:grid;grid-template-columns:280px 1fr;gap:64px;align-items:start}

/* LEFT STICKY NAV */
.sticky-left{position:sticky;top:96px}
.snav{display:flex;flex-direction:column;gap:2px;position:relative;padding-left:20px}
.snav::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--border);border-radius:2px}
.snav-progress{position:absolute;left:0;top:0;width:2px;background:linear-gradient(180deg,var(--teal),var(--teal-light));border-radius:2px;transition:height 0.15s linear;z-index:1}
.snav-item{padding:12px 16px;border-radius:10px;cursor:pointer;transition:all 0.25s;border:1px solid transparent;text-decoration:none;display:block}
.snav-item:hover{background:rgba(14,162,122,0.04)}
.snav-item.active{background:white;border-color:var(--border);box-shadow:0 4px 16px rgba(0,0,0,0.07)}
.sni-num{font-size:10px;font-weight:700;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:2px;transition:color 0.2s}
.snav-item.active .sni-num{color:var(--teal)}
.sni-title{font-size:13px;font-weight:500;color:var(--mid);line-height:1.4;transition:color 0.2s}
.snav-item.active .sni-title{color:var(--ink);font-weight:600}

/* SOLUTION BLOCKS */
.sol-blocks{display:flex;flex-direction:column;gap:0}
.sol-block{min-height:90vh;display:flex;align-items:center;padding:60px 0;border-bottom:1px solid var(--border)}
.sol-block:last-child{border-bottom:none}

.sol-card{background:white;border:1px solid var(--border);border-radius:24px;padding:52px;width:100%;box-shadow:0 4px 24px rgba(0,0,0,0.05);transition:all 0.4s;position:relative;overflow:hidden}
.sol-card::after{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--teal),var(--teal-light));transform:scaleX(0);transform-origin:left;transition:transform 0.5s ease}
.sol-block.in-view .sol-card{box-shadow:0 20px 72px rgba(14,162,122,0.1);border-color:rgba(14,162,122,0.18);transform:translateY(-4px)}
.sol-block.in-view .sol-card::after{transform:scaleX(1)}

.sol-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:28px;gap:20px}
.sol-left-head{}
.sol-stag{display:inline-flex;align-items:center;gap:6px;background:var(--teal-pale);border-radius:4px;padding:3px 10px;font-size:10px;font-weight:600;color:var(--teal);letter-spacing:0.5px;text-transform:uppercase;margin-bottom:14px}
.sol-icon-big{font-size:52px;line-height:1;filter:drop-shadow(0 6px 16px rgba(14,162,122,0.2))}
.sol-title{font-family:'Fraunces',serif;font-size:clamp(26px,2.5vw,38px);font-weight:300;line-height:1.1;letter-spacing:-1px;margin-top:14px;color:var(--ink)}
.sol-title em{font-style:italic;color:var(--teal)}
.sol-desc{font-size:15px;color:var(--mid);line-height:1.85;margin-bottom:32px;max-width:560px}

.sol-body{display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start}
.sol-features{display:flex;flex-direction:column;gap:10px}
.sol-feat{display:flex;align-items:flex-start;gap:10px;padding:12px 14px;background:var(--bg);border:1px solid var(--border);border-radius:10px;transition:all 0.2s}
.sol-feat:hover{border-color:var(--teal);background:var(--teal-pale)}
.sol-check{color:var(--teal);font-weight:700;font-size:13px;margin-top:1px;flex-shrink:0}
.sol-feat-text{font-size:13px;color:var(--mid);line-height:1.5}
.sol-pills{display:flex;flex-wrap:wrap;gap:7px;margin-top:16px}
.sol-pill{font-size:11px;padding:4px 12px;background:white;border:1px solid var(--border);color:var(--mid);border-radius:20px;font-weight:500}

/* Visual panel inside card */
.sol-visual{background:var(--dark2);border-radius:16px;padding:24px;position:relative;overflow:hidden;height:100%}
.sol-visual::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 40%,rgba(14,162,122,0.08),transparent 65%)}
.sol-vis-title{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:16px;position:relative}
.sol-code{font-family:'Courier New',monospace;font-size:12px;line-height:1.9;position:relative}
.sc-dim{color:rgba(255,255,255,0.25)}
.sc-key{color:rgba(14,162,122,0.9)}
.sc-val{color:#E8C97A}
.sc-ok{color:rgba(18,201,148,0.85)}
.sol-metrics{display:flex;gap:10px;margin-top:16px;position:relative}
.sol-metric{flex:1;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:10px;padding:12px;text-align:center}
.sm-num{font-family:'Fraunces',serif;font-size:22px;font-weight:300;color:var(--teal-light);line-height:1}
.sm-label{font-size:10px;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:1px;margin-top:3px}

.sol-cta-link{display:inline-flex;align-items:center;gap:8px;color:var(--teal);font-size:14px;font-weight:600;text-decoration:none;margin-top:28px;transition:gap 0.2s}
.sol-cta-link:hover{gap:14px}

/* STATS BAR */
.sol-stats{background:var(--dark);position:relative;overflow:hidden}
.sol-stats::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 50% 0%,rgba(14,162,122,0.07),transparent)}
.sol-stats-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);position:relative}
.sol-stat{padding:44px 32px;border-right:1px solid rgba(255,255,255,0.06);text-align:center}
.sol-stat:last-child{border-right:none}
.sol-stat-num{font-family:'Fraunces',serif;font-size:42px;font-weight:300;color:var(--teal-light);text-shadow:0 0 40px rgba(18,201,148,0.35);line-height:1;margin-bottom:6px}
.sol-stat-label{font-size:12px;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:1px}

/* CTA BAND */
.cta-band{background:linear-gradient(135deg,#071810,#0a2018);padding:100px 60px;text-align:center;position:relative;overflow:hidden}
.cta-band::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 80% at 50% 50%,rgba(14,162,122,0.09),transparent)}
.cta-band h2{font-family:'Fraunces',serif;font-size:clamp(30px,4vw,54px);font-weight:300;color:white;letter-spacing:-1px;line-height:1.1;margin-bottom:16px;position:relative}
.cta-band h2 em{font-style:italic;color:var(--teal-light)}
.cta-band p{font-size:17px;color:rgba(255,255,255,0.45);max-width:460px;margin:0 auto 40px;line-height:1.75;position:relative}
.cta-actions{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;position:relative}
.btn-white{background:white;color:var(--ink);padding:14px 36px;border-radius:10px;font-weight:700;font-size:15px;cursor:pointer;border:none;font-family:'Plus Jakarta Sans',sans-serif;transition:all 0.2s;text-decoration:none;display:inline-block}
.btn-white:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(255,255,255,0.15)}
.btn-outline-w{background:transparent;color:white;padding:14px 36px;border-radius:10px;font-weight:500;font-size:15px;cursor:pointer;border:1.5px solid rgba(255,255,255,0.2);font-family:'Plus Jakarta Sans',sans-serif;transition:all 0.2s;text-decoration:none;display:inline-block}
.btn-outline-w:hover{border-color:var(--teal-light);color:var(--teal-light)}

/* FOOTER */
footer{background:var(--dark2);border-top:1px solid rgba(255,255,255,0.06);padding:36px 60px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:20px}
.footer-logo{font-size:18px;font-weight:700;color:white}
.footer-logo span{color:var(--teal)}
.footer-links{display:flex;gap:28px;list-style:none;flex-wrap:wrap}
.footer-links a{color:rgba(255,255,255,0.3);text-decoration:none;font-size:13px;transition:color 0.2s}
.footer-links a:hover{color:white}
.footer-copy{font-size:12px;color:rgba(255,255,255,0.18)}

/* MOBILE */
@media(max-width:900px){
  nav{padding:0 20px}
  .nav-links,.nav-cta{display:none}
  .hamburger{display:flex}
  .page-hero-inner{grid-template-columns:1fr;padding:0;gap:40px}
  .page-hero{padding:120px 20px 60px}
  .sticky-section{padding:48px 20px 80px}
  .sticky-wrap{grid-template-columns:1fr}
  .sticky-left{display:none}
  .sol-block{min-height:auto;padding:28px 0}
  .sol-card{padding:28px 20px;border-radius:16px}
  .sol-header{flex-direction:column}
  .sol-body{grid-template-columns:1fr}
  .sol-stats-inner{grid-template-columns:1fr 1fr}
  .sol-stat{padding:28px 16px;border-bottom:1px solid rgba(255,255,255,0.06)}
  .sol-stat:nth-child(even){border-right:none}
  .cta-band{padding:64px 20px}
  footer{padding:28px 20px;flex-direction:column;align-items:flex-start}
}
</style>
</head>
